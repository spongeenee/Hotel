<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.Bloom?>
<?import javafx.scene.effect.Reflection?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane
        minHeight="-Infinity" minWidth="-Infinity"
        prefHeight="900.0" prefWidth="1400.0"
        xmlns="http://javafx.com/javafx/26"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.example.hotel.controller.SupervisorController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <left>
        <VBox alignment="TOP_CENTER" spacing="10.0" BorderPane.alignment="CENTER">
            <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="150.0" VBox.vgrow="NEVER">
                <Label text="Hoteles y Resort">
                    <font>
                        <Font name="Fira Sans Compressed ExtraLight" size="19.0" />
                    </font>
                </Label>
                <Label text="MERU">
                    <font>
                        <Font name="FontAwesome" size="73.0" />
                    </font>
                    <effect>
                        <Reflection fraction="0.35" />
                    </effect>
                </Label>
                <effect>
                    <Bloom />
                </effect>
            </VBox>
            <VBox alignment="TOP_CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                <Button maxWidth="Infinity" mnemonicParsing="false" text="Dashboard" VBox.vgrow="ALWAYS">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </Button>
                <Button maxWidth="Infinity" mnemonicParsing="false" text="Gestionar reservaciones" VBox.vgrow="ALWAYS">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </Button>
                <Button maxWidth="Infinity" mnemonicParsing="false" text="Gestionar habitaciones" VBox.vgrow="ALWAYS">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </Button>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Gestionar catálogos" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Ver auditoria" />
                <padding>
                    <Insets bottom="5.0" right="5.0" top="20.0" />
                </padding>
            </VBox>
        </VBox>
    </left>

   <center>
       <StackPane prefHeight="150.0" prefWidth="200.0" BorderPane.alignment="TOP_CENTER">
           <padding>
               <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
           </padding>
           <VBox fx:id="reservacionPane" alignment="CENTER" spacing="20.0">
               <VBox alignment="TOP_RIGHT">
                   <HBox alignment="TOP_CENTER" spacing="10.0">
                       <TextField maxWidth="Infinity" promptText="Nombre del huesped" HBox.hgrow="ALWAYS"
                                  VBox.vgrow="ALWAYS"/>
                       <TextField promptText="Correo del huesped" HBox.hgrow="ALWAYS"/>
                       <ChoiceBox prefWidth="150.0"/>
                       <DatePicker fx:id="datePicker"/>
                       <DatePicker/>
                       <CheckBox mnemonicParsing="false" text="Confirmado"/>
                       <CheckBox mnemonicParsing="false" text="Pagado"/>
                   </HBox>
                   <Button mnemonicParsing="false" text="Button"/>
               </VBox>
               <TableView VBox.vgrow="ALWAYS">
                   <columnResizePolicy>
                       <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                   </columnResizePolicy>
                   <columns>
                       <TableColumn editable="false" reorderable="false" resizable="false" text="ID"/>
                       <TableColumn editable="false" prefWidth="200" reorderable="false" resizable="false"
                                    text="Correo"/>
                       <TableColumn editable="false" prefWidth="100" reorderable="false" resizable="false"
                                    text="Habitación"/>
                       <TableColumn editable="false" prefWidth="100" reorderable="false" resizable="false"
                                    text="Estado"/>
                       <TableColumn editable="false" reorderable="false" text="Fecha de registro"/>
                       <TableColumn editable="false" reorderable="false" text="Fecha de ingreso"/>
                       <TableColumn editable="false" reorderable="false" text="Fecha de salida"/>
                   </columns>
               </TableView>
               <Label fx:id="date"/>
           </VBox>
       </StackPane>
   </center>

   <bottom>
       <HBox alignment="CENTER" spacing="5.0">
           <Label text="Usuario actual: "/>
           <Label text="Example"/>
           <Label text="Rol:"/>
           <Label text="ADMIN"/>
           <Region HBox.hgrow="ALWAYS"/>
           <Label text="Hora actual:"/>
           <Label fx:id="hora"/>
       </HBox>
   </bottom>

    <right>
        <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
            <StackPane fx:id="contenedorCalendario" VBox.vgrow="ALWAYS" />
        </VBox>
    </right>

</BorderPane>
