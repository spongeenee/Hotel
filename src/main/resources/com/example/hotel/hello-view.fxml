<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.hotel.controller.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <center>
        <StackPane fx:id="menuContenedor">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
            <VBox fx:id="dashboard" alignment="CENTER" spacing="20.0">

            </VBox>
            <!-- Gestion de Reservaciones -->
            <VBox fx:id="reservacionPane" alignment="CENTER" spacing="20.0">
                <VBox alignment="TOP_RIGHT">
                    <HBox alignment="TOP_CENTER" spacing="10.0">
                        <TextField maxWidth="Infinity" promptText="Nombre del huesped" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" />
                        <TextField promptText="Correo del huesped" HBox.hgrow="ALWAYS" />
                        <ChoiceBox prefWidth="150.0" />
                        <DatePicker fx:id="datePicker" onAction="#showDatePicker" />
                        <DatePicker />
                        <CheckBox mnemonicParsing="false" text="Confirmado" />
                        <CheckBox mnemonicParsing="false" text="Pagado" />
                    </HBox>
                    <Button mnemonicParsing="false" text="Button" />
                </VBox>
                <TableView VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn editable="false" reorderable="false" resizable="false" text="ID" />
                        <TableColumn editable="false" prefWidth="200" reorderable="false" resizable="false" text="Correo" />
                        <TableColumn editable="false" prefWidth="100" reorderable="false" resizable="false" text="Habitación" />
                        <TableColumn editable="false" prefWidth="100" reorderable="false" resizable="false" text="Estado" />
                        <TableColumn editable="false" reorderable="false" text="Fecha de registro" />
                        <TableColumn editable="false" reorderable="false" text="Fecha de ingreso" />
                        <TableColumn editable="false" reorderable="false" text="Fecha de salida" />
                    </columns>
                </TableView>
                <Label fx:id="date" />
            </VBox>
            <VBox fx:id="huespedesPane" alignment="CENTER" spacing="20.0">
                <VBox alignment="TOP_RIGHT">
                    <HBox alignment="TOP_CENTER" spacing="10.0">
                        <TextField maxWidth="Infinity" promptText="Nombre del huesped" VBox.vgrow="ALWAYS" />
                        <TextField promptText="Correo del huesped" />
                        <ChoiceBox prefWidth="150.0" />
                        <DatePicker onAction="#showDatePicker" />
                        <CheckBox mnemonicParsing="false" text="Confirmado" />
                        <CheckBox mnemonicParsing="false" text="Pagado" />
                    </HBox>
                    <Button mnemonicParsing="false" text="Button" />
                </VBox>
                <TableView VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn editable="false" prefWidth="300.0" reorderable="false" resizable="false" text="Nombre" />
                        <TableColumn editable="false" prefWidth="200" reorderable="false" resizable="false" text="Correo" />
                        <TableColumn editable="false" prefWidth="100" reorderable="false" resizable="false" text="Habitación" />
                        <TableColumn editable="false" reorderable="false" text="Fecha de registro" />
                        <TableColumn editable="false" reorderable="false" text="Fecha de ingreso" />
                        <TableColumn editable="false" reorderable="false" text="Fecha de salida" />
                    </columns>
                </TableView>
            </VBox>
        </StackPane>
   </center>
    <left>
        <VBox alignment="TOP_CENTER" spacing="10.0" BorderPane.alignment="CENTER">
            <Button maxWidth="Infinity" mnemonicParsing="false" text="Dashboard" VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#mostrarReservacionPane" text="Registro de reservas" VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#mostrarHuespedesPane" text="Control de huespedes" VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" mnemonicParsing="false" text="Control de aplicaciones" VBox.vgrow="ALWAYS" />
        </VBox>
    </left>
   <right>
       <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
           <StackPane fx:id="contenedorCalendario" VBox.vgrow="ALWAYS" />
       </VBox>
   </right>
   <top>
       <HBox alignment="CENTER" spacing="5.0" BorderPane.alignment="CENTER">
           <padding>
               <Insets bottom="20.0"/>
           </padding>
           <Label text="Usuario actual: "/>
           <Label text="Example"/>
           <Label text="Rol:"/>
           <Label text="ADMIN"/>
           <Region HBox.hgrow="ALWAYS"/>
           <Label text="Hora actual:"/>
           <Label text="HORA"/>
       </HBox>
   </top>
</BorderPane>
