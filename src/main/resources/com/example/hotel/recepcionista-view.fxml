<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.effect.Bloom?>
<?import javafx.scene.effect.Reflection?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1400.0" stylesheets="@estilos.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.hotel.controller.RecepcionistaController">

    <center>
        <VBox BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
         <Label fx:id="encabezado" text="Example" VBox.vgrow="ALWAYS">
            <padding>
               <Insets left="20.0" right="20.0" />
            </padding>
            <font>
               <Font name="System Bold" size="24.0" />
            </font>
         </Label>

            <!-- Totalidad -->
            <StackPane fx:id="menuContenedor" VBox.vgrow="ALWAYS">

                <!-- Dashboard -->
                <VBox fx:id="dashboard" alignment="CENTER" spacing="20.0" StackPane.alignment="TOP_CENTER">
                    <HBox spacing="10" VBox.vgrow="ALWAYS">
                        <VBox fx:id="KPIentradas" spacing="10.0" style="-fx-background-color: linear-gradient(#ececec, #cfcfcf); -fx-border-color: #b4b4b4;" HBox.hgrow="ALWAYS">
                        </VBox>
                        <VBox fx:id="KPIsalidas" spacing="10.0" style="-fx-background-color: linear-gradient(#ececec, #cfcfcf); -fx-border-color: #b4b4b4;" HBox.hgrow="ALWAYS">
                        </VBox>
                        <VBox fx:id="KPIrecientes" spacing="10.0" style="-fx-background-color: linear-gradient(#ececec, #cfcfcf); -fx-border-color: #b4b4b4;" HBox.hgrow="ALWAYS">
                        </VBox>
                    </HBox>
                    <HBox alignment="TOP_CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Próximos check-ins" />
                            <TableView prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn prefWidth="75.0" text="C1" />
                                    <TableColumn prefWidth="75.0" text="C2" />
                                </columns>
                            </TableView>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Próximos chech-outs" />
                            <TableView prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn prefWidth="75.0" text="C1" />
                                    <TableColumn prefWidth="75.0" text="C2" />
                                </columns>
                            </TableView>
                        </VBox>
                    </HBox>
                    <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#registrarReservacion" text="Agregar Reservación" />
                </VBox>

                <!-- Gestión de reservaciones -->
                <VBox fx:id="reservacionPane" alignment="TOP_RIGHT" spacing="20.0" StackPane.alignment="CENTER_RIGHT">
                    <VBox alignment="CENTER_RIGHT" spacing="10.0">
                        <HBox alignment="TOP_CENTER" spacing="10.0">
                            <TextField fx:id="registroNombre" maxWidth="Infinity" promptText="Nombre del huesped" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" />
                            <TextField fx:id="registroCorreo" promptText="Correo del huesped" HBox.hgrow="ALWAYS" />
                            <ChoiceBox prefWidth="150.0" />
                            <DatePicker fx:id="registroDesde" promptText="Fecha de Ingreso" />
                            <DatePicker fx:id="registroHasta" promptText="Fecha de Salida" />
                            <ChoiceBox accessibleText="ESTADO" prefWidth="150.0" />
                        </HBox>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <Button mnemonicParsing="false" text="Limpiar" />
                            <Button mnemonicParsing="false" text="Buscar" />
                        </HBox>
                    </VBox>
                    <TableView fx:id="reservacionTableView" VBox.vgrow="ALWAYS">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="reservacionIDColumn" editable="false" reorderable="false" resizable="false" text="ID" />
                            <TableColumn prefWidth="100.0" text="Nombre" />
                            <TableColumn fx:id="reservacionCorreoColumn" editable="false" prefWidth="200" reorderable="false" resizable="false" text="Correo" />
                            <TableColumn fx:id="reservacionHabitacionColumn" editable="false" prefWidth="100" reorderable="false" resizable="false" text="Habitación" />
                            <TableColumn fx:id="reservacionEstadoColumn" editable="false" prefWidth="100" reorderable="false" resizable="false" text="Estado" />
                            <TableColumn fx:id="reservacionRegistoColumn" editable="false" reorderable="false" text="Fecha de registro" />
                            <TableColumn fx:id="reservacionIngresoColumn" editable="false" reorderable="false" text="Fecha de ingreso" />
                            <TableColumn fx:id="reservacionSalidaColumn" editable="false" reorderable="false" text="Fecha de salida" />
                        </columns>
                    </TableView>
                    <HBox alignment="CENTER_RIGHT" spacing="10.0" VBox.vgrow="NEVER">
                        <Button mnemonicParsing="false" onAction="#registrarReservacion" text="Registrar" />
                        <Button mnemonicParsing="false" text="Check-In" />
                        <Button mnemonicParsing="false" text="Check-out" />
                    </HBox>
                </VBox>

                <!-- Registro de Habitaciones -->
                <VBox fx:id="huespedesPane" alignment="CENTER" spacing="20.0">
                    <HBox spacing="10.0" VBox.vgrow="ALWAYS">
                        <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                            <TitledPane collapsible="false" VBox.vgrow="ALWAYS">
                                <graphic>
                                    <HBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308">
                                        <padding>
                                            <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                                        </padding>
                                        <Label text="Habitación" HBox.hgrow="ALWAYS" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label text="TIPO" HBox.hgrow="ALWAYS" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label text="Disponible" HBox.hgrow="ALWAYS" />
                                    </HBox>
                                </graphic>
                                <VBox>
                                    <HBox>
                                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                            <HBox.margin>
                                                <Insets />
                                            </HBox.margin>
                                            <padding>
                                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                            </padding>
                                            <Label text="Huesped:" />
                                            <Label text="Fecha de ingreso:" />
                                            <Label text="Fecha de salida:" />
                                            <Label text="Pago:" />
                                            <Label text="Estado:" />
                                        </VBox>
                                        <VBox alignment="TOP_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
                                            <HBox.margin>
                                                <Insets />
                                            </HBox.margin>
                                            <padding>
                                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                            </padding>
                                            <Label text="HUESPED" />
                                            <Label text="REGISTRO" />
                                            <Label text="SALIDA" />
                                            <Label text="PENDIENTE" />
                                            <Label text="RESERVADO" />
                                        </VBox>
                                    </HBox>
                                    <Region prefHeight="100.0" VBox.vgrow="ALWAYS" />
                                </VBox>
                            </TitledPane>
                        </VBox>
                        <GridPane fx:id="habitacionesWidget" />
                    </HBox>
                    <HBox alignment="TOP_RIGHT" spacing="10.0">
                        <Button mnemonicParsing="false" text="Generar Excel" />
                        <Button mnemonicParsing="false" text="Generar Excel" />
                    </HBox>
                </VBox>

                <VBox.margin>
                    <Insets />
                </VBox.margin>
            <padding>
               <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            </StackPane>
        </VBox>
    </center>

    <left>
        <VBox alignment="TOP_CENTER" spacing="10.0" styleClass="fondo-principal" BorderPane.alignment="CENTER">
            <VBox VBox.vgrow="ALWAYS">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>
                <!-- Titulo -->
                <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="150.0" VBox.vgrow="NEVER">
                    <Label text="Hoteles y Resort" textFill="WHITE">
                        <font>
                            <Font name="Fira Sans Compressed ExtraLight" size="19.0" />
                        </font>
                    </Label>
                    <Label text="MERU" textFill="WHITE">
                        <font>
                            <Font name="FontAwesome" size="73.0" />
                        </font>
                        <effect>
                            <Reflection fraction="0.35" />
                        </effect>
                    </Label>
                    <effect>
                        <Bloom />
                    </effect>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>

                <!-- Botones -->
                <VBox alignment="TOP_CENTER" spacing="10.0" styleClass="base-navegacion" VBox.vgrow="ALWAYS">
                    <Button maxWidth="Infinity" onAction="#mostrarDashboardPane" styleClass="navegacion-button" text="Dashboard" textFill="WHITE" VBox.vgrow="ALWAYS">
                        <cursor>
                            <Cursor fx:constant="HAND" />
                        </cursor>
                    </Button>
                    <Button maxWidth="Infinity" onAction="#mostrarReservacionPane" styleClass="navegacion-button" text="Registro de reservas" textFill="WHITE" VBox.vgrow="ALWAYS">
                        <cursor>
                            <Cursor fx:constant="HAND" />
                        </cursor>
                    </Button>
                    <Button maxWidth="Infinity" onAction="#mostrarHuespedesPane" styleClass="navegacion-button" text="Registro de habitaciones" textFill="WHITE" VBox.vgrow="ALWAYS">
                        <cursor>
                            <Cursor fx:constant="HAND" />
                        </cursor>
                    </Button>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>
            </VBox>
        </VBox>
    </left>

   <right>
       <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
           <StackPane fx:id="calendarioWidget" VBox.vgrow="ALWAYS" />
       </VBox>
   </right>

   <bottom>
         <!-- Barra de sesión -->
         <HBox alignment="CENTER" spacing="10.0" styleClass="top-bar" BorderPane.alignment="CENTER">
             <Label text="Usuario actual: " textFill="WHITE" />
             <Label text="Example" textFill="WHITE" />
             <Label text="Rol:" textFill="WHITE" />
             <Label text="ADMIN" textFill="WHITE" />
         <Region HBox.hgrow="ALWAYS" />
       <Button onAction="#cerrarSesion" styleClass="navegacion-button" text="Cerrar Sesión" textFill="WHITE" />
         <Button onAction="#salir" styleClass="navegacion-button" text="Salir" textFill="WHITE" />
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
         </padding>
         </HBox>
   </bottom>
</BorderPane>
