<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.Bloom?>
<?import javafx.scene.effect.Reflection?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane minHeight="-Infinity" minWidth="-Infinity" prefHeight="900.0" prefWidth="1400.0" stylesheets="@estilos.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.hotel.controller.RecepcionistaController">

    <center>
        <VBox BorderPane.alignment="TOP_CENTER">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <!-- Barra de sesión -->
            <HBox spacing="5.0" VBox.vgrow="NEVER">
                <Label text="Usuario actual: " />
                <Label text="Example" />
                <Label text="Rol:" />
                <Label text="ADMIN" />
                <Label fx:id="hora" />
            </HBox>

            <!-- Totalidad -->
            <StackPane fx:id="menuContenedor" VBox.vgrow="ALWAYS">

                <!-- Dashboard -->
                <VBox fx:id="dashboard" alignment="CENTER" spacing="20.0" visible="false" StackPane.alignment="TOP_CENTER">
                    <HBox spacing="10" VBox.vgrow="ALWAYS">
                        <VBox fx:id="KPIentradas" spacing="10.0" style="-fx-background-color: linear-gradient(#ececec, #cfcfcf); -fx-border-color: #b4b4b4;" HBox.hgrow="ALWAYS">
                        </VBox>
                        <VBox fx:id="KPIsalidas" spacing="10.0" style="-fx-background-color: linear-gradient(#ececec, #cfcfcf); -fx-border-color: #b4b4b4;" HBox.hgrow="ALWAYS">
                        </VBox>
                        <VBox fx:id="KPIrecientes" spacing="10.0" style="-fx-background-color: linear-gradient(#ececec, #cfcfcf); -fx-border-color: #b4b4b4;" HBox.hgrow="ALWAYS">
                        </VBox>
                    </HBox>
                    <HBox alignment="TOP_CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0" VBox.vgrow="ALWAYS">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Próximos check-ins" />
                            <TableView prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn prefWidth="75.0" text="C1" />
                                    <TableColumn prefWidth="75.0" text="C2" />
                                </columns>
                            </TableView>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Próximos chech-outs" />
                            <TableView prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn prefWidth="75.0" text="C1" />
                                    <TableColumn prefWidth="75.0" text="C2" />
                                </columns>
                            </TableView>
                        </VBox>
                    </HBox>
                    <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Agregar Reservación" />
                </VBox>

                <!-- Gestion de Reservaciones -->
                <VBox fx:id="reservacionPane" alignment="CENTER" spacing="20.0" visible="false">
                    <VBox alignment="TOP_RIGHT" spacing="10.0">
                        <HBox alignment="TOP_CENTER" spacing="10.0">
                            <TextField maxWidth="Infinity" promptText="Nombre del huesped" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" />
                            <TextField promptText="Correo del huesped" HBox.hgrow="ALWAYS" />
                            <ChoiceBox prefWidth="150.0" />
                            <DatePicker fx:id="datePicker" onAction="#showDatePicker" promptText="Fecha de Ingreso" />
                            <DatePicker promptText="Fecha de Salida" />
                            <ChoiceBox accessibleText="ESTADO" prefWidth="150.0" />
                        </HBox>
                        <Button mnemonicParsing="false" text="Registrar reservacion" />
                    </VBox>
                    <TableView VBox.vgrow="ALWAYS">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <columns>
                            <TableColumn editable="false" reorderable="false" resizable="false" text="ID" />
                            <TableColumn editable="false" prefWidth="200" reorderable="false" resizable="false" text="Correo" />
                            <TableColumn editable="false" prefWidth="100" reorderable="false" resizable="false" text="Habitación" />
                            <TableColumn editable="false" prefWidth="100" reorderable="false" resizable="false" text="Estado" />
                            <TableColumn editable="false" reorderable="false" text="Fecha de registro" />
                            <TableColumn editable="false" reorderable="false" text="Fecha de ingreso" />
                            <TableColumn editable="false" reorderable="false" text="Fecha de salida" />
                        </columns>
                    </TableView>
                    <GridPane fx:id="contenedorHabitaciones" alignment="CENTER" VBox.vgrow="ALWAYS" />
                </VBox>

                <!-- Registro de Huespedes -->
                <VBox fx:id="huespedesPane" alignment="CENTER" spacing="20.0">
                    <VBox alignment="TOP_RIGHT" spacing="10.0">
                        <HBox alignment="TOP_CENTER" spacing="10.0">
                            <TextField maxWidth="Infinity" promptText="Nombre del huesped" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" />
                            <TextField promptText="Correo del huesped" HBox.hgrow="ALWAYS" />
                            <ChoiceBox prefWidth="150.0" />
                            <DatePicker onAction="#showDatePicker" />
                            <DatePicker />
                        </HBox>
                        <Button mnemonicParsing="false" text="Buscar" />
                    </VBox>
                    <TableView VBox.vgrow="ALWAYS">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <columns>
                            <TableColumn editable="false" prefWidth="300.0" reorderable="false" resizable="false" text="Nombre" />
                            <TableColumn editable="false" prefWidth="200" reorderable="false" resizable="false" text="Correo" />
                            <TableColumn editable="false" prefWidth="100" reorderable="false" resizable="false" text="Habitación" />
                            <TableColumn editable="false" reorderable="false" text="Fecha de registro" />
                            <TableColumn editable="false" reorderable="false" text="Fecha de ingreso" />
                            <TableColumn editable="false" reorderable="false" text="Fecha de salida" />
                        </columns>
                    </TableView>
                    <HBox alignment="TOP_RIGHT" spacing="10.0">
                        <Button mnemonicParsing="false" text="Generar Excel"/>
                        <Button mnemonicParsing="false" text="Generar Excel"/>
                    </HBox>
                </VBox>

                <VBox.margin>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </VBox.margin>
            </StackPane>
        </VBox>
   </center>

    <left>
        <VBox alignment="TOP_CENTER" spacing="10.0" styleClass="fondo-principal" BorderPane.alignment="CENTER">
            <VBox VBox.vgrow="NEVER">
                <padding>
                    <Insets bottom="10.0" left="20.0" right="10.0" top="20.0" />
                </padding>
                <!-- Titulo -->
                <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="150.0" VBox.vgrow="NEVER">
                    <Label text="Hoteles y Resort" textFill="WHITE">
                        <font>
                            <Font name="Fira Sans Compressed ExtraLight" size="19.0" />
                        </font>
                    </Label>
                    <Label text="MERU" textFill="WHITE">
                        <font>
                            <Font name="FontAwesome" size="73.0" />
                        </font>
                        <effect>
                            <Reflection fraction="0.35" />
                        </effect>
                    </Label>
                    <effect>
                        <Bloom />
                    </effect>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>

                <!-- Botones -->
                <VBox alignment="TOP_CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                    <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#mostrarDashboardPane" text="Dashboard" VBox.vgrow="ALWAYS">
                        <cursor>
                            <Cursor fx:constant="HAND" />
                        </cursor>
                    </Button>
                    <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#mostrarReservacionPane" text="Registro de reservas" VBox.vgrow="ALWAYS">
                        <cursor>
                            <Cursor fx:constant="HAND" />
                        </cursor>
                    </Button>
                    <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#mostrarHuespedesPane" text="Lista de huespedes" VBox.vgrow="ALWAYS">
                        <cursor>
                            <Cursor fx:constant="HAND" />
                        </cursor>
                    </Button>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>
            </VBox>
        </VBox>
    </left>

   <right>
       <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
           <StackPane fx:id="contenedorCalendario" VBox.vgrow="ALWAYS" />
       </VBox>
   </right>
</BorderPane>
