<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.Bloom?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="300.0" prefWidth="900.0" stylesheets="@estilos.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.hotel.controller.RegistroController">

    <left>
        <VBox maxHeight="Infinity" maxWidth="Infinity" styleClass="fondo-principal" VBox.vgrow="NEVER">
            <Label text="Registro de" textFill="WHITE">
                <font>
                    <Font name="Fira Sans Compressed ExtraLight" size="19.0" />
                </font>
            </Label>
         <Label text="Reservación" textFill="WHITE">
            <font>
               <Font name="Fira Sans Compressed ExtraLight" size="19.0" />
            </font>
         </Label>
            <effect>
                <Bloom />
            </effect>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </VBox>
    </left>

    <center>
        <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <Label text="Nombre:" />
                <TextField fx:id="nombre" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <Label text="Correo:" />
                <TextField fx:id="correo" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <Label text="Fecha de entrada:" />
                <Region HBox.hgrow="ALWAYS" />
                <DatePicker fx:id="fechaEntrada" promptText="Entradas a las 12" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <Label text="Fecha de salida:" />
                <Region HBox.hgrow="ALWAYS" />
                <DatePicker fx:id="fechaSalida" promptText="Salida a las 12" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <Label text="Estado:" />
                <Region HBox.hgrow="ALWAYS" />
                <ChoiceBox fx:id="estado" prefWidth="150.0" HBox.hgrow="ALWAYS" />
            </HBox>
            <Label />
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
        </VBox>
    </center>
   <right>
       <VBox alignment="TOP_RIGHT" spacing="10.0" BorderPane.alignment="CENTER">
           <padding>
               <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
           </padding>
           <GridPane fx:id="habitacionPanel" />
         <Region VBox.vgrow="ALWAYS" />
         <Button mnemonicParsing="false" text="Registrar" onAction="#registrar"/>
       </VBox>
   </right>
</BorderPane>
