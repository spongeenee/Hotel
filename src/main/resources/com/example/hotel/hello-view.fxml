<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.hotel.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <center>
        <StackPane>
            <padding>
                <Insets left="20.0" />
            </padding>
            <VBox alignment="CENTER" spacing="20.0">
                <VBox alignment="TOP_RIGHT">
                    <HBox alignment="TOP_CENTER" spacing="10.0" VBox.vgrow="NEVER">
                        <TextField promptText="Nombre del huesped" />
                        <TextField promptText="Correo del huesped" />
                        <ChoiceBox prefWidth="150.0" />
                        <DatePicker fx:id="datePicker" onAction="#showDatePicker" />
                        <DatePicker />
                        <CheckBox mnemonicParsing="false" text="Confirmado" />
                        <CheckBox mnemonicParsing="false" text="Pagado" />
                    </HBox>
                    <Button mnemonicParsing="false" text="Button" />
                </VBox>
                <TableView VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn editable="false" reorderable="false" resizable="false" text="ID" />
                        <TableColumn editable="false" reorderable="false" prefWidth="200" resizable="false" text="Correo" />
                        <TableColumn editable="false" reorderable="false" prefWidth="100" resizable="false" text="Habitación" />
                        <TableColumn editable="false" reorderable="false" prefWidth="100" resizable="false" text="Estado" />
                        <TableColumn editable="false" reorderable="false" text="Fecha de registro" />
                        <TableColumn editable="false" reorderable="false" text="Fecha de ingreso" />
                        <TableColumn editable="false" reorderable="false" text="Fecha de salida" />
                    </columns>
                </TableView>
                <Label fx:id="date" />
            </VBox>
        </StackPane>
   </center>
    <left>
        <VBox alignment="TOP_CENTER" spacing="10.0" BorderPane.alignment="CENTER">
            <Button maxWidth="Infinity" mnemonicParsing="false" text="Dashboard" VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" mnemonicParsing="false" text="Registro de reservas" VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" mnemonicParsing="false" text="Control de huespedes" VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" mnemonicParsing="false" text="Control de aplicaciones" VBox.vgrow="ALWAYS" />
        </VBox>
    </left>
</BorderPane>
